# ─── Stripe ───────────────────────────────────────────────────────────────────
# Use sk_test_... during dev/test, sk_live_... when going live
STRIPE_SECRET_KEY=sk_test_...

# $200 one-time build fee price ID (Dashboard → Products → Website Build Fee → Price ID)
STRIPE_SETUP_PRICE_ID=price_...

# $19/month recurring price ID (Dashboard → Products → Monthly Hosting → Price ID)
STRIPE_PRICE_ID=price_...

# From Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Settings → API → anon / public key (safe to expose to frontend via get-config)
SUPABASE_ANON_KEY=eyJ...

# Settings → API → service_role key (backend only — never expose to client)
SUPABASE_SERVICE_KEY=eyJ...

# ─── Cloudflare ───────────────────────────────────────────────────────────────
# My Profile → API Tokens → Create Token → Edit Cloudflare Workers template
CLOUDFLARE_API_TOKEN=...

# Right sidebar on any Cloudflare dashboard page
CLOUDFLARE_ACCOUNT_ID=...

# ─── Name.com (domain registrar) ──────────────────────────────────────────────
# Account → API → Create API Token
NAMECOM_USERNAME=your-namecom-username
NAMECOM_TOKEN=...

# Registrant contact info — used when registering customer domains on their behalf
NAMECOM_REG_FIRST=Bedrock
NAMECOM_REG_LAST=Digital
NAMECOM_REG_COMPANY=Bedrock Sites LLC
NAMECOM_REG_ADDRESS=123 Main St
NAMECOM_REG_CITY=Rexburg
NAMECOM_REG_STATE=ID
NAMECOM_REG_ZIP=83440
NAMECOM_REG_PHONE=+1.2085550100
NAMECOM_REG_EMAIL=hello@bedrock-sites.com

# ─── Resend (email) ───────────────────────────────────────────────────────────
# API Keys → Create API Key
RESEND_API_KEY=re_...

# Verified sending domain (must be verified in Resend dashboard)
RESEND_FROM=hello@bedrock-sites.com

# Where to send "new claim" and "new payment" notifications
NOTIFY_EMAIL=brockniederer@gmail.com

# ─── App config ───────────────────────────────────────────────────────────────
# Your live site URL (no trailing slash)
SITE_URL=https://bedrock-sites.com

# Random string — protects the manual deploy endpoint. Use: openssl rand -hex 16
DEPLOY_SECRET=change-me
